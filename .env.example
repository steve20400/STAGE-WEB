# Backend Next.js (prod Vercel) — pour du local : http://localhost:3000
VITE_API_BASE_URL=https://backend-alanya.vercel.app
# Serveur WebSocket (prod Render) — pour du local : ws://localhost:3001
VITE_WS_URL=wss://alanya-ws.onrender.com
VITE_DATA_MODE=auto

# TURN (appels entre reseaux differents). Optionnel si le backend a METERED_API_KEY.
# Exemple avec un compte gratuit metered.ca :
# VITE_TURN_URLS=turn:standard.relay.metered.ca:80,turn:standard.relay.metered.ca:443,turns:standard.relay.metered.ca:443?transport=tcp
# VITE_TURN_USERNAME=...
# VITE_TURN_CREDENTIAL=...
