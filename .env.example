# Backend Next.js (prod Vercel) — pour du local : http://localhost:3000
VITE_API_BASE_URL=https://backend-alanya.vercel.app
# Serveur WebSocket (prod Render) — pour du local : ws://localhost:3001
VITE_WS_URL=wss://alanya-ws.onrender.com
VITE_DATA_MODE=auto

# TURN (appels entre reseaux differents).
# Le serveur par defaut du projet (open.alanya.cloud) est code en dur dans
# src/services/calls-service.ts : aucune variable n'est requise pour que les
# appels fonctionnent. Definir VITE_TURN_* permet seulement de surcharger avec
# un autre fournisseur (tests, comparaison) :
# VITE_TURN_URLS=turns:open.alanya.cloud:443?transport=tcp
# VITE_TURN_USERNAME=...
# VITE_TURN_CREDENTIAL=...
