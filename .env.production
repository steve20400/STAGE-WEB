# URLs de production embarquees au build (Vercel, Netlify, etc.)
# Ce sont des URLs publiques : aucun secret ici.
VITE_API_BASE_URL=https://backend-alanya.vercel.app
VITE_WS_URL=wss://alanya-ws.onrender.com
VITE_DATA_MODE=api

