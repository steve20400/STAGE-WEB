# URLs de production embarquees au build (Vercel, Netlify, etc.)
# Ce sont des URLs publiques : aucun secret ici.
VITE_API_BASE_URL=https://backend-alanya.vercel.app
VITE_WS_URL=wss://alanya-ws.onrender.com
VITE_DATA_MODE=api

# Configuration Firebase Client (FCM Web Push)
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_FIREBASE_AUTH_DOMAIN
VITE_FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_FIREBASE_MESSAGING_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_FIREBASE_APP_ID
VITE_FIREBASE_VAPID_KEY=YOUR_FIREBASE_VAPID_KEY

# Le relais TURN (appels entre reseaux differents) se configure dans les
# variables d'environnement Vercel du projet (pas ici, le repo est public) :
#   VITE_TURN_URLS, VITE_TURN_USERNAME, VITE_TURN_CREDENTIAL
# Voir .env.example pour le format.
